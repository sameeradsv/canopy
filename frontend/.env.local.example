# Local dev
NEXT_PUBLIC_API_URL=http://localhost:8000

# Optional: Shared Cortex Auth Server — enables cross-app accounts (Canopy, Chef, Circuit).
# Leave blank to use Canopy-only local accounts.
NEXT_PUBLIC_CORTEX_URL=http://localhost:7000

# Production (set in Vercel / Render / Netlify env vars)
# NEXT_PUBLIC_API_URL=https://canopy-api.onrender.com
# NEXT_PUBLIC_CORTEX_URL=https://cortex-auth.onrender.com
